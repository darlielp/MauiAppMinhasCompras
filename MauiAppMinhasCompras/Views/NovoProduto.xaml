<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.NovoProduto"
             Title="Novo Produto"
             BackgroundColor="#F5F5F5">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Salvar" Clicked="ToolbarItem_Clicked"/>
    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <ResourceDictionary>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="#222"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>

        </ResourceDictionary>
    </ContentPage.Resources>

    <VerticalStackLayout Padding="15" Spacing="12">

        <Label Text="Descrição" FontAttributes="Bold"/>
        <Frame CornerRadius="8"
               Padding="5"
               BackgroundColor="White"
               BorderColor="#CCCCCC"
               HasShadow="False">
            <Entry x:Name="txt_descricao"
                   TextColor="#222"
                   Placeholder="Digite a descrição"/>
        </Frame>

        <Label Text="Quantidade" FontAttributes="Bold"/>
        <Frame CornerRadius="8"
               Padding="5"
               BackgroundColor="White"
               BorderColor="#CCCCCC"
               HasShadow="False">
            <Entry x:Name="txt_quantidade"
                   Keyboard="Numeric"
                   TextColor="#222"
                   Placeholder="0"/>
        </Frame>

        <Label Text="Categoria" FontAttributes="Bold"/>
        <Frame CornerRadius="8"
               Padding="5"
               BackgroundColor="White"
               BorderColor="#CCCCCC"
               HasShadow="False">
            <Picker x:Name="picker_categoria"
                    TextColor="#222">
                <Picker.Items>
                    <x:String>Alimentos</x:String>
                    <x:String>Higiene</x:String>
                    <x:String>Limpeza</x:String>
                </Picker.Items>
            </Picker>
        </Frame>

        <Label Text="Preço Unitário" FontAttributes="Bold"/>
        <Frame CornerRadius="8"
               Padding="5"
               BackgroundColor="White"
               BorderColor="#CCCCCC"
               HasShadow="False">
            <Entry x:Name="txt_preco"
                   Keyboard="Numeric"
                   TextColor="#222"
                   Placeholder="0,00"/>
        </Frame>

    </VerticalStackLayout>
</ContentPage>